# ── Authentication (set exactly one) ───────────────────────────────────────────

# Option A — Claude Code OAuth token (recommended)
# Run `claude setup-token` on your desktop to generate a 1-year token, then
# paste the value here.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Option B — Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-...

# ── Workspace ───────────────────────────────────────────────────────────────────

# Absolute path to the directory the agent will run in.
# Docker Desktop handles Windows paths automatically (e.g. C:/Users/you/project).
WORKSPACE_PATH=/path/to/your/project
